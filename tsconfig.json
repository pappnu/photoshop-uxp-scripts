{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "rootDir": "./src",
    "outDir": "./dist",
    "noImplicitAny": true,
    "module": "CommonJS",
    "target": "ES2017",
    "allowJs": false,
    "moduleResolution": "node",
    "typeRoots": ["./node_modules/@types"]
  },
  "include": ["src/**/*"]
}
